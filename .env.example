# Aljamea-Maktabat .env.example
# Copy to .env and customize

# Flask Security
SECRET_KEY=your-super-secret-key-here-change-in-production

# Admin login (CHANGE IMMEDIATELY!)
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# Email (Gmail/Office365/SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=Maktabat al-Jamea <your-email@gmail.com>

# Koha Database (read-only)
KOHA_DB_HOST=your-koha-host
KOHA_DB_USER=library_read
KOHA_DB_PASS=your-readonly-password
KOHA_DB_NAME=koha_library
KOHA_OPAC_BASE_URL=https://your-opac-url

# Scheduler (CRON-like)
REPORT_SEND_DAY=1
REPORT_SEND_HOUR=8
REPORT_SEND_MINUTE=0

# Development
FLASK_DEBUG=false
USE_WAITRESS=true
MAIL_SUPPRESS_SEND=false

# Production
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=None
